# Backend starter environment reference
# This file documents the variables the FastAPI starter reads.
# Load them through your shell, process manager, or deployment system.

APP_API_KEY=dev-key-change-me
APP_SESSION_SECRET=replace-this-before-sharing-the-app
APP_ADMIN_USERS=admin
APP_CORS_ORIGINS=http://localhost:3000
APP_SESSION_COOKIE_NAME=app_session
APP_SESSION_TTL_SECONDS=28800
APP_SESSION_SECURE_COOKIE=false
# Set to "none" when frontend and backend are on different origins (requires Secure=true).
# Default "lax" works for same-origin and localhost development.
APP_SESSION_SAMESITE=lax
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Rate limiting (per-IP sliding window)
RATE_LIMIT_RPM=120
RATE_LIMIT_WINDOW_SECONDS=60

# Dojo (ocfa) integration — root directory for project files (config, artifacts, etc.)
# Structure: {DOJO_STORAGE_DIR}/{project_id}/config.json
DOJO_STORAGE_DIR=/path/to/superseis_storage
