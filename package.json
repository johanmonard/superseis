{
  "name": "seiseye",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node scripts/setup.mjs",
    "new-module": "node scripts/new-module.mjs",
    "remove-module": "node scripts/remove-module.mjs",
    "preflight": "node scripts/preflight.mjs",
    "db:migrate": "cd api && alembic revision --autogenerate -m",
    "db:upgrade": "cd api && alembic upgrade head",
    "db:downgrade": "cd api && alembic downgrade -1",
    "db:status": "cd api && alembic current",
    "prepare": "husky"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@geoman-io/leaflet-geoman-free": "^2.19.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@types/leaflet": "^1.9.21",
    "@types/proj4": "^2.5.6",
    "@xyflow/react": "^12.10.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.564.0",
    "maplibre-gl": "^5.22.0",
    "next": "16.1.6",
    "proj4": "^2.20.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-simple-maps": "^3.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-simple-maps": "^3.0.6",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^25",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
