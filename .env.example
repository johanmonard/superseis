# Frontend starter environment
# Copy this file to .env.local when the frontend needs to talk to the API.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
NEXT_PUBLIC_API_REQUEST_TIMEOUT_MS=15000
# Set this to disable the dev auth warning banner (e.g. "okta", "auth0", "custom")
# NEXT_PUBLIC_AUTH_PROVIDER=
